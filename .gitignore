# ==============================================
# Keil MDK-ARM — 编译器构建产物
# ==============================================

# 目标文件
*.o

# 交叉引用文件
*.crf

# 依赖文件
*.d

# ELF 调试文件 (非常大)
*.axf

# 固件烧录文件 (由源码生成)
*.hex
*.bin

# 链接器 Map 文件
*.map

# 构建系统依赖
*.dep

# 链接器输入文件
*.lnp

# Keil 扩展 DLL
*.iex

# 构建报告 / 汇编列表
*.build_log.htm
*.lst

# Event Recorder 存根
*.scvd

# 仅匹配 MDK-ARM 目录下的 .htm (避免误伤文档)
**/MDK-ARM/**/*.htm

# CMSIS Pack 生成
**/MDK-ARM/RTE/

# Keil 个人 GUI 布局 (含用户名)
*.uvguix.*

# 备份文件
*.bak

# ==============================================
# Python
# ==============================================

# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# PyInstaller 构建
pc_software/build/
pc_software/dist/

# 虚拟环境 (如后续创建)
.venv/
venv/
env/

# ==============================================
# STM32CubeMX
# ==============================================

# 本地元数据 (含用户特定路径)
.mxproject

# ==============================================
# IDE & 编辑器
# ==============================================

.vscode/
.idea/
.vs/

# 旧版 TrueSTUDIO/Eclipse (可在确认不再使用后取消注释)
# .project
# .cproject
# .settings/

# ==============================================
# 操作系统
# ==============================================

# Windows
Thumbs.db
[Dd]esktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ==============================================
# 杂项
# ==============================================

*.log
*.tmp
*.temp
*.swp
*.swo
*~

# ==============================================
# 内嵌 Git 仓库
# ==============================================
# new_control_v2/ 有自己独立的 Git 仓库。
# 如果不想让根仓库追踪它，取消下面注释:
# new_control_v2/
